# ==============================================================================
# Clahan Academy - Environment Configuration Template (.env.example)
# ==============================================================================
# Copy this file to '.env' and populate with your own values.
# Do NOT commit the actual '.env' file containing your production secrets to Git.

# ------------------------------------------------------------------------------
# 1. Twilio SendGrid Integration (Recommended for Production Emails)
# ------------------------------------------------------------------------------
# Set the API key generated from SendGrid (Full Access to "Mail Send" permission)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# The verified sender email or domain sender configured in SendGrid Sender Authentication
SENDGRID_FROM=noreply@yourdomain.com

# ------------------------------------------------------------------------------
# 2. Database (PostgreSQL) Configuration
# ------------------------------------------------------------------------------
# Credentials used to initialize the PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clahan

# Connection URL for microservices to connect to the database container
# (If running outside Docker, replace 'postgres' with your database host/IP)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/clahan

# ------------------------------------------------------------------------------
# 3. Cache (Redis) Configuration
# ------------------------------------------------------------------------------
# Connection URL for microservices to connect to the Redis container
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------------------------
# 4. JWT Security Keys
# ------------------------------------------------------------------------------
# Secret tokens used to sign and verify user session tokens
JWT_ACCESS_SECRET=your_super_secret_access_token_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here

# ------------------------------------------------------------------------------
# 5. Core Platform Links
# ------------------------------------------------------------------------------
# The fully-qualified URL where the frontend portal is accessible (e.g. for links in emails)
FRONTEND_URL=https://clahanacademy.com

# ------------------------------------------------------------------------------
# 6. Legacy SMTP Configuration (Fallback if SendGrid is not configured)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=aiexamplatform123@gmail.com
SMTP_PASS=zmsoiamljdkhwpxn
SMTP_FROM=aiexamplatform123@gmail.com

# ------------------------------------------------------------------------------
# 7. AI Proctoring & Coding Evaluation Run-times
# ------------------------------------------------------------------------------
# Host URLs for the proctoring modules and LLM services
AI_SERVICE_URL=http://ai-service:8000
OLLAMA_URL=http://ollama-service:11434
YOLO_URL=http://yolo-service:8081
FACE_URL=http://face-service:8082
OCR_URL=http://ocr-service:8083
